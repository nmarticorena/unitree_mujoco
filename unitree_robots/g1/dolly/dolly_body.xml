<?xml version="1.0"?>
<mujocoinclude>
  <!-- <freejoint name="dolly_free"/> -->
  <joint name="box_x" type="slide" axis="1 0 0" damping="0.1" frictionloss="10"/>
  <joint name="box_y" type="slide" axis="0 1 0" damping="0.1" frictionloss="10"/>
  <joint name="box_yaw" type="hinge" axis="0 0 1" damping="0.05" frictionloss="5"/>

  <geom rgba="1 1 1 1" mesh="dolly_mesh" material="dolly_mat" class="visual"
        quat="0.7071068 0.7071068 0 0"/>

  <geom name="dolly_bottom_box_collision" type="box" class="collision"
        pos="0 0 -0.3" size="0.5 0.32 0.15" mass="3"/>

  <geom name="dolly_front_handle_collision_left" type="capsule" class="collision"
        fromto="0.4 0.13 -0.3  0.4 0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>
  <geom name="dolly_front_handle_collision_right" type="capsule" class="collision"
        fromto="0.4 -0.13 -0.3  0.4 -0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>
  <geom name="dolly_front_handle_collision_top" type="capsule" class="collision"
        fromto="0.45 -0.13 0.45  0.45 0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>

  <geom name="dolly_back_handle_collision_left" type="capsule" class="collision"
        fromto="-0.4 0.13 -0.3  -0.4 0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>
  <geom name="dolly_back_handle_collision_right" type="capsule" class="collision"
        fromto="-0.4 -0.13 -0.3  -0.4 -0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>
  <geom name="dolly_back_handle_collision_top" type="capsule" class="collision"
        fromto="-0.45 -0.13 0.45  -0.45 0.13 0.45" size="0.03" rgba="0.2 0.2 0.2 1"/>
</mujocoinclude>
